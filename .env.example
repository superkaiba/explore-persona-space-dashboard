# --- Supabase (project settings → API Keys) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...           # server-only, never ship to client

# --- Postgres (Supabase project → Connect → App Frameworks → Next.js → Transaction pooler) ---
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- Site URL (used by GitHub OAuth callback) ---
NEXT_PUBLIC_SITE_URL=https://your-vercel-url.vercel.app

# --- Literature workflow ingest (VM sync -> Vercel API) ---
LIT_INGEST_SECRET=generate-a-long-random-token

# --- Anthropic (used by the chat agent in milestone 7) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Sidecar URL (Cloudflare Tunnel to the Python agent process; milestone 7) ---
NEXT_PUBLIC_SIDECAR_URL=https://chat.YOUR-DOMAIN.com
# Local dev can leave NEXT_PUBLIC_SIDECAR_URL empty and use the same-origin
# proxy at /api/sidecar, which forwards to SIDECAR_INTERNAL_URL.
SIDECAR_INTERNAL_URL=http://127.0.0.1:7654
