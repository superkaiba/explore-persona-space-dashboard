# --- Auth ---
# Shared secret the Vercel /api/chat-full proxy sends in Authorization: Bearer <token>.
# Generate one: `openssl rand -hex 32`
SIDECAR_SHARED_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Working directory the agent operates in ---
# Defaults to this dashboard repo because the sidecar is the dashboard improvement runner.
EPS_WORKDIR=/home/thomasjiralerspong/explore-persona-space-dashboard

# --- Bind ---
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=7654

# --- Per-request safety rails ---
SIDECAR_TIMEOUT_S=300                # subprocess wall-clock cap
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_MODEL=opus
CLAUDE_EFFORT=xhigh
CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh

# --- Paths to agent binaries ---
CLAUDE_BIN=/home/thomasjiralerspong/.local/bin/claude
CODEX_BIN=/home/thomasjiralerspong/.npm-global/bin/codex
