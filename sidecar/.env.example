# --- Auth ---
# Shared secret the Vercel /api/chat-full proxy sends in Authorization: Bearer <token>.
# Generate one: `openssl rand -hex 32`
SIDECAR_SHARED_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Working directory the agent operates in ---
# Defaults to the research repo so the agent can read commits, eval results, etc.
EPS_WORKDIR=/home/thomasjiralerspong/explore-persona-space

# --- Bind ---
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=7654

# --- Per-message budget cap (fewer turns = lower cost; more turns = better answers) ---
SIDECAR_MAX_TURNS=15

# --- Model ---
SIDECAR_MODEL=claude-sonnet-4-6
